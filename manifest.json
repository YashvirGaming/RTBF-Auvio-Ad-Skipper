{
  "manifest_version": 3,
  "name": "RTBF Auvio Ad Skipper",
  "version": "1.0",
  "description": "Automatically fast-forwards RTBF Auvio ad breaks.",
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://auvio.rtbf.be/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}